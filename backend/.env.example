# Copy this file to .env and fill in real values. Never commit .env.

DATABASE_URL="postgresql://tracker:tracker@localhost:5432/task_tracker?schema=public"

# Access token — short lived, returned in the response body.
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh token — long lived, stored hashed in DB, set as httpOnly cookie.
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Frontend origin — used for CORS, must be exact (not *) because cookies
# are involved (credentials: true).
FRONTEND_ORIGIN="http://localhost:3000"

PORT=3001
NODE_ENV="development"
