{
  "info": {
    "name": "Task Tracker API",
    "description": "Full API collection for the Task Tracker application.\n\nSetup:\n1. Set `baseUrl` variable (default: http://localhost:3001)\n2. Run \"Register\" or \"Login\" — accessToken is saved automatically\n3. Create a workspace, then use its ID for subsequent requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "workspaceId", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Test User\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "  if (data.user) pm.collectionVariables.set('userId', data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "  if (data.user) pm.collectionVariables.set('userId', data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/health/live", "host": ["{{baseUrl}}"], "path": ["health", "live"] }
          }
        },
        {
          "name": "Readiness",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/health/ready", "host": ["{{baseUrl}}"], "path": ["health", "ready"] }
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Workspace\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('workspaceId', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List My Workspaces",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] }
          }
        },
        {
          "name": "Get Workspace",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}"] }
          }
        },
        {
          "name": "Update Workspace",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed Workspace\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Workspace",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}"] }
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "members"] }
          }
        },
        {
          "name": "Add Member",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "members"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"member@example.com\",\n  \"role\": \"MEMBER\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members/{{userId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "members", "{{userId}}"] }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/projects", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "projects"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Project\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('projectId', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/projects", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "projects"] }
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "projects", "{{projectId}}"] }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "projects", "{{projectId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed Project\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "projects", "{{projectId}}"] }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/tasks", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "tasks"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Task\",\n  \"description\": \"Task description\",\n  \"status\": \"TODO\",\n  \"projectId\": \"{{projectId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('taskId', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Tasks by Project",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/tasks?projectId={{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["workspaces", "{{workspaceId}}", "tasks"],
              "query": [{ "key": "projectId", "value": "{{projectId}}" }]
            }
          }
        },
        {
          "name": "Get Task",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "tasks", "{{taskId}}"] }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "tasks", "{{taskId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Task Title\",\n  \"status\": \"IN_PROGRESS\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Task — Assign User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "tasks", "{{taskId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assigneeId\": \"{{userId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Task — Unassign",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "tasks", "{{taskId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assigneeId\": null\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Reorder Task",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/tasks/{{taskId}}/reorder", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "tasks", "{{taskId}}", "reorder"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"order\": 1000\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "tasks", "{{taskId}}"] }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Status Breakdown",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/analytics/status-breakdown", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "analytics", "status-breakdown"] }
          }
        },
        {
          "name": "Activity (last 30 days)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/analytics/activity?days=30",
              "host": ["{{baseUrl}}"],
              "path": ["workspaces", "{{workspaceId}}", "analytics", "activity"],
              "query": [{ "key": "days", "value": "30" }]
            }
          }
        },
        {
          "name": "Assignee Load",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/analytics/assignee-load", "host": ["{{baseUrl}}"], "path": ["workspaces", "{{workspaceId}}", "analytics", "assignee-load"] }
          }
        }
      ]
    }
  ]
}
